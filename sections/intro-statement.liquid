<style>
  .intro-statement {
    background: #000;
    padding: var(--section-padding-v, 100px) var(--section-padding-h, 60px);
  }

  .intro-statement__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: var(--max-width, 1400px);
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .intro-statement__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
  }

  /* ── Text column ── */
  .intro-statement__eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 1.6rem;
  }

  .intro-statement__heading {
    color: #fff;
    font-family: var(--font-heading, 'Helvetica Neue', Helvetica, Arial, sans-serif);
    font-weight: 300;
    font-size: 2.2rem;
    line-height: 1.25;
    margin-bottom: 1.8rem;
  }

  @media screen and (min-width: 750px) {
    .intro-statement__heading {
      font-size: 3rem;
    }
  }

  .intro-statement__body {
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-body, 'Helvetica Neue', Helvetica, Arial, sans-serif);
    font-size: 16px;
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── Image column ── */
  .intro-statement__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    min-height: 340px;
  }

  @media screen and (min-width: 750px) {
    .intro-statement__image-wrap {
      min-height: 480px;
    }
  }

  .intro-statement__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
  }

  .intro-statement__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #1a1a1a;
  }
</style>

<section class="intro-statement" id="intro-statement-{{ section.id }}">
  <div class="intro-statement__grid">
    {%- comment -%} Text column {%- endcomment -%}
    <div class="intro-statement__text">
      <p class="intro-statement__eyebrow">The Future of Indoor Lighting.</p>

      {% if section.settings.heading != blank %}
        <h2 class="intro-statement__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.body_text != blank %}
        <p class="intro-statement__body">{{ section.settings.body_text }}</p>
      {% endif %}
    </div>

    {%- comment -%} Image column {%- endcomment -%}
    <div class="intro-statement__image-wrap">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 750px) 50vw, 100vw',
            widths: '400,600,800,1000,1400',
            class: 'intro-statement__img'
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'intro-statement__img intro-statement__placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Intro Statement",
  "tag": "section",
  "class": "intro-statement-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Future of Indoor Lighting."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "SUNROOOF is the worlds first wellness lighting technology that brings the experience and benefits of sunlight inside any space through advanced optics, special lenses and AI. Transforming dull, dark and lifeless areas to beautiful sunlit courtyard experiences."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Intro Statement"
    }
  ]
}
{% endschema %}
