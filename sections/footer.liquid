<style>
  .sunrooof-footer {
    background: #000;
    padding: 80px 60px 40px;
    color: #fff;
    font-family: var(--font-body-family, 'Inter', sans-serif);
    font-size: 13px;
    line-height: 1.7;
  }

  .sunrooof-footer * {
    box-sizing: border-box;
  }

  .sunrooof-footer a {
    color: #fff;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  .sunrooof-footer a:hover {
    opacity: 0.7;
  }

  .sunrooof-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
    gap: 40px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── Column headings ── */
  .sunrooof-footer__heading {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 11px;
    opacity: 0.5;
    margin: 0 0 20px;
    font-weight: 600;
  }

  /* ── Column 1 — Brand ── */
  .sunrooof-footer__logo {
    max-width: 140px;
    margin-bottom: 16px;
  }

  .sunrooof-footer__logo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .sunrooof-footer__tagline {
    opacity: 0.6;
    margin: 0 0 24px;
    font-size: 13px;
  }

  .sunrooof-footer__social {
    display: flex;
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sunrooof-footer__social a {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.6;
  }

  .sunrooof-footer__social a:hover {
    opacity: 1;
  }

  /* ── Column 2 — Quick Links ── */
  .sunrooof-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sunrooof-footer__links li {
    margin-bottom: 10px;
  }

  .sunrooof-footer__links a {
    opacity: 0.75;
    font-size: 13px;
  }

  .sunrooof-footer__links a:hover {
    opacity: 1;
  }

  /* ── Column 3 — Contact ── */
  .sunrooof-footer__contact-item {
    display: block;
    opacity: 0.75;
    margin-bottom: 10px;
    font-size: 13px;
  }

  .sunrooof-footer__contact-item a {
    opacity: 1;
  }

  /* ── Column 4 — Newsletter ── */
  .sunrooof-footer__newsletter-text {
    opacity: 0.6;
    margin: 0 0 20px;
    font-size: 13px;
  }

  .sunrooof-footer__newsletter-form {
    display: flex;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 0;
    overflow: hidden;
    max-width: 400px;
  }

  .sunrooof-footer__newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    padding: 12px 16px;
    font-size: 13px;
    font-family: inherit;
    outline: none;
  }

  .sunrooof-footer__newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .sunrooof-footer__newsletter-btn {
    background: transparent;
    border: none;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.25s ease;
    white-space: nowrap;
  }

  .sunrooof-footer__newsletter-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .sunrooof-footer__newsletter-msg {
    margin-top: 10px;
    font-size: 12px;
  }

  .sunrooof-footer__newsletter-msg--error {
    color: #ff6b6b;
  }

  .sunrooof-footer__newsletter-msg--success {
    color: #51cf66;
  }

  /* ── Bottom bar ── */
  .sunrooof-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 60px;
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .sunrooof-footer__copyright {
    opacity: 0.4;
    font-size: 12px;
  }

  .sunrooof-footer__legal {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 12px;
  }

  .sunrooof-footer__legal a {
    opacity: 0.4;
  }

  .sunrooof-footer__legal a:hover {
    opacity: 0.8;
  }

  .sunrooof-footer__legal-sep {
    opacity: 0.2;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 999px) {
    .sunrooof-footer {
      padding: 60px 40px 30px;
    }

    .sunrooof-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px 30px;
    }
  }

  @media screen and (max-width: 599px) {
    .sunrooof-footer {
      padding: 48px 24px 24px;
    }

    .sunrooof-footer__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .sunrooof-footer__bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

<footer class="sunrooof-footer" role="contentinfo">
  <div class="sunrooof-footer__grid">
    <!-- Column 1 — Brand -->
    <div class="sunrooof-footer__col">
      <div class="sunrooof-footer__logo">
        <a href="{{ routes.root_url }}">
          {%- if section.settings.footer_logo != blank -%}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 200 }}"
              alt="{{ shop.name }}"
              width="140"
              height="40"
              loading="lazy"
            >
          {%- else -%}
            <span style="font-size:18px; font-weight:700; letter-spacing:0.08em; color:#fff;">
              {{ shop.name | upcase }}
            </span>
          {%- endif -%}
        </a>
      </div>
      <p class="sunrooof-footer__tagline">The Future of Indoor Lighting</p>
      <ul class="sunrooof-footer__social">
        <li><a href="https://www.instagram.com/sunrooof_/" target="_blank" rel="noopener noreferrer">INSTAGRAM</a></li>
        <li><a href="https://www.youtube.com/@Sunrooof" target="_blank" rel="noopener noreferrer">YOUTUBE</a></li>
      </ul>
    </div>

    <!-- Column 2 — Quick Links -->
    <div class="sunrooof-footer__col">
      <h2 class="sunrooof-footer__heading">Quick Links</h2>
      <ul class="sunrooof-footer__links">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><a href="{{ routes.all_products_collection_url }}">Products</a></li>
        <li><a href="/pages/gallery">Gallery</a></li>
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="/pages/our-team">Our Team</a></li>
        <li><a href="/pages/faqs">FAQs</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
      </ul>
    </div>

    <!-- Column 3 — Contact -->
    <div class="sunrooof-footer__col">
      <h2 class="sunrooof-footer__heading">Contact</h2>
      <span class="sunrooof-footer__contact-item">
        <a href="tel:+919811773388">+91 9811773388</a>
      </span>
      <span class="sunrooof-footer__contact-item">
        <a href="mailto:CONTACT@SUNROOOF.COM">CONTACT@SUNROOOF.COM</a>
      </span>
    </div>

    <!-- Column 4 — Newsletter -->
    <div class="sunrooof-footer__col">
      <p class="sunrooof-footer__newsletter-text">Subscribe for updates and lighting inspiration.</p>
      {%- form 'customer', id: 'FooterNewsletterForm' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="sunrooof-footer__newsletter-form">
          <input
            class="sunrooof-footer__newsletter-input"
            type="email"
            name="contact[email]"
            id="FooterNewsletterEmail"
            placeholder="Your email address"
            value="{{ form.email }}"
            aria-required="true"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="FooterNewsletter-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="FooterNewsletter-success"
            {% endif %}
          >
          <button type="submit" class="sunrooof-footer__newsletter-btn" aria-label="Subscribe">Subscribe</button>
        </div>
        {%- if form.errors -%}
          <p class="sunrooof-footer__newsletter-msg sunrooof-footer__newsletter-msg--error" id="FooterNewsletter-error">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <p
            class="sunrooof-footer__newsletter-msg sunrooof-footer__newsletter-msg--success"
            id="FooterNewsletter-success"
          >
            Thanks for subscribing!
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="sunrooof-footer__bottom">
    <div class="sunrooof-footer__copyright">&copy; 2025 SUNROOOF. All rights reserved.</div>
    <div class="sunrooof-footer__legal">
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <span class="sunrooof-footer__legal-sep">|</span>
      <a href="/policies/terms-of-service">Terms of Service</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [{ "type": "image_picker", "id": "footer_logo", "label": "Footer Logo" }]
}
{% endschema %}
