<div class="controls-carousel-section">
  <div class="controls-carousel-header">
    {% if section.settings.heading != blank %}
      <h2 class="controls-carousel-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="controls-carousel-subtext">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>

  <div class="controls-carousel-wrapper">
    <div class="controls-carousel-track">
      {% for block in section.blocks %}
        <div class="controls-carousel-card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="controls-carousel-card-link">
            <div class="card-image-wrapper">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | escape }}" width="400" height="400" loading="lazy">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="card-title">
              {{ block.settings.title }}
            </div>
          </a>
        </div>
      {% endfor %}
      
      {% comment %} Duplicated blocks for infinite scrolling {% endcomment %}
      {% for block in section.blocks %}
        <div class="controls-carousel-card is-duplicate" aria-hidden="true">
          <a href="{{ block.settings.link | default: '#' }}" class="controls-carousel-card-link" tabindex="-1">
            <div class="card-image-wrapper">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | escape }}" width="400" height="400" loading="lazy">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="card-title">
              {{ block.settings.title }}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.controls-carousel-section {
  background-color: #000;
  padding: 100px 60px;
  overflow: hidden;
  color: #fff;
}

.controls-carousel-header {
  text-align: center;
  margin-bottom: 40px;
}

.controls-carousel-heading {
  font-size: 2.5rem;
  margin: 0 0 10px 0;
  font-weight: 500;
  color: #fff;
}

.controls-carousel-subtext {
  opacity: 0.65;
  max-width: 800px;
  margin: 0 auto;
  font-size: 1rem;
  line-height: 1.5;
}

.controls-carousel-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.controls-carousel-track {
  display: flex;
  gap: 20px;
  width: max-content;
  animation: scroll-carousel 20s linear infinite;
}

.controls-carousel-wrapper:hover .controls-carousel-track {
  animation-play-state: paused;
}

.controls-carousel-card {
  width: 250px;
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.controls-carousel-card:hover {
  transform: translateY(-5px);
}

.controls-carousel-card-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

.card-image-wrapper {
  background: #fff;
  padding: 20px;
  aspect-ratio: 1/1;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15px;
  border-radius: 8px;
}

.card-image-wrapper img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.card-image-wrapper svg {
  width: 100%;
  height: 100%;
  fill: #ccc;
}

.card-title {
  color: #fff;
  font-size: 14px;
  text-align: center;
}

@keyframes scroll-carousel {
  0% { transform: translateX(0); }
  100% { transform: translateX(calc(-50% - 10px)); }
}

@media screen and (max-width: 768px) {
  .controls-carousel-section {
    padding: 60px 20px;
  }
  .controls-carousel-heading {
    font-size: 2rem;
  }
  .controls-carousel-wrapper {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar for a cleaner look */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .controls-carousel-wrapper::-webkit-scrollbar {
    display: none;
  }
  .controls-carousel-track {
    animation: none;
    padding-bottom: 10px;
  }
  .controls-carousel-card {
    width: 200px;
    scroll-snap-align: start;
  }
  /* Hide the duplicate elements on mobile since we have native scrolling */
  .controls-carousel-card.is-duplicate {
    display: none;
  }
}
</style>

{% schema %}
{
  "name": "Controls Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Control The SUNROOF Manually"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Connect via Wi-Fi, adjust with a premium-finish remote, or manage seamlessly through the SUNROOOF app on iOS and Android and SUNROOOF Controller."
    }
  ],
  "blocks": [
    {
      "type": "control_product",
      "name": "Control Product",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Name",
          "default": "Magnetic Keypad White"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Controls Carousel",
      "blocks": [
        {
          "type": "control_product",
          "settings": {
            "title": "Magnetic Keypad White"
          }
        },
        {
          "type": "control_product",
          "settings": {
            "title": "Tabletop Rotary Remote Black"
          }
        },
        {
          "type": "control_product",
          "settings": {
            "title": "Magnetic Keypad Black"
          }
        }
      ]
    }
  ]
}
{% endschema %}
