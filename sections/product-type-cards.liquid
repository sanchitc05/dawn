{% style %}
  .ptc-section {
    background-color: #000;
    padding-top: 100px;
    padding-bottom: 60px;
  }
  .ptc-heading {
    color: #fff;
    font-size: 2.5rem;
    text-align: center;
    margin: 0 0 40px;
    padding: 0 20px;
  }
  .ptc-cards {
    display: flex;
    gap: 20px;
    padding: 0 60px;
  }
  .ptc-card {
    position: relative;
    flex: 1 1 50%;
    height: 600px;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }
  .ptc-card .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #222;
    fill: #555;
  }
  .ptc-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }
  .ptc-card:hover img {
    transform: scale(1.03);
  }
  .ptc-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
    pointer-events: none;
  }
  .ptc-card-content {
    position: absolute;
    bottom: 40px;
    left: 40px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 15px;
  }
  .ptc-card-label {
    color: #fff;
    font-size: 1.5rem;
    margin: 0;
    font-weight: 500;
  }
  .ptc-card-btn {
    color: #fff;
    font-size: 0.9rem;
    text-decoration: none;
    border-bottom: 1px solid #fff;
    padding-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: opacity 0.3s ease;
  }
  .ptc-card:hover .ptc-card-btn {
    opacity: 0.7;
  }

  @media screen and (max-width: 768px) {
    .ptc-section {
      padding-top: 60px;
      padding-bottom: 40px;
    }
    .ptc-heading {
      font-size: 2rem;
      margin-bottom: 30px;
    }
    .ptc-cards {
      flex-direction: column;
      padding: 0;
      gap: 0; /* Edge to edge on mobile */
    }
    .ptc-card {
      height: 450px;
    }
    .ptc-card-content {
      bottom: 30px;
      left: 30px;
    }
  }
{% endstyle %}

<div class="ptc-section">
  {% if section.settings.heading != blank %}
    <h2 class="ptc-heading">{{ section.settings.heading }}</h2>
  {% endif %}
  <div class="ptc-cards">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="ptc-card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        <div class="ptc-card-overlay"></div>
        <div class="ptc-card-content">
          {% if block.settings.label != blank %}
            <h3 class="ptc-card-label">{{ block.settings.label }}</h3>
          {% endif %}
          {% if block.settings.button_text != blank %}
            <span class="ptc-card-btn">{{ block.settings.button_text }}</span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Product Type Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ceilings and windows we got both covered"
    }
  ],
  "max_blocks": 2,
  "blocks": [
    {
      "type": "product_type",
      "name": "Product Type",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Explore all products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Type Cards",
      "blocks": [
        {
          "type": "product_type",
          "settings": {
            "label": "Skylight",
            "link": "/collections?tab=CEILING",
            "button_text": "Explore all products"
          }
        },
        {
          "type": "product_type",
          "settings": {
            "label": "Window",
            "link": "/collections?tab=WINDOW",
            "button_text": "Explore all products"
          }
        }
      ]
    }
  ]
}
{% endschema %}
