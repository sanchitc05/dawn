{{ 'video-features.css' | asset_url | stylesheet_tag }}

<section class="video-features" id="video-features-{{ section.id }}">
  <div class="video-features__container">
    {% if section.settings.heading != blank %}
      <h2 class="video-features__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="video-features__grid">
      {% for block in section.blocks %}
        <div class="video-features__item" {{ block.shopify_attributes }}>
          <div class="video-features__video-wrapper">
            <video
              class="video-features__video"
              autoplay
              muted
              loop
              playsinline
              {% if block.settings.thumbnail %}poster="{{ block.settings.thumbnail | image_url: width: 800 }}"{% endif %}
              {% if block.settings.video_url != blank %}src="{{ block.settings.video_url }}"{% endif %}
            ></video>
          </div>
          {% if block.settings.caption != blank %}
            <p class="video-features__caption">{{ block.settings.caption }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="video-features__controls">
      <button
        type="button"
        class="video-features__toggle"
        id="video-toggle-{{ section.id }}"
        aria-label="Pause all videos"
      >
        <svg class="video-features__icon video-features__icon--pause" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="2" width="4" height="14" rx="1" fill="currentColor"/>
          <rect x="11" y="2" width="4" height="14" rx="1" fill="currentColor"/>
        </svg>
        <svg class="video-features__icon video-features__icon--play" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none;">
          <path d="M4 2.5V15.5L15 9L4 2.5Z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.getElementById('video-features-{{ section.id }}');
    if (!section) return;

    const toggle = section.querySelector('#video-toggle-{{ section.id }}');
    const videos = section.querySelectorAll('.video-features__video');
    const pauseIcon = toggle.querySelector('.video-features__icon--pause');
    const playIcon = toggle.querySelector('.video-features__icon--play');
    let isPlaying = true;

    toggle.addEventListener('click', function () {
      if (isPlaying) {
        videos.forEach(function (v) { v.pause(); });
        pauseIcon.style.display = 'none';
        playIcon.style.display = 'block';
        toggle.setAttribute('aria-label', 'Play all videos');
      } else {
        videos.forEach(function (v) { v.play(); });
        pauseIcon.style.display = 'block';
        playIcon.style.display = 'none';
        toggle.setAttribute('aria-label', 'Pause all videos');
      }
      isPlaying = !isPlaying;
    });
  })();
</script>

{% schema %}
{
  "name": "Video Features",
  "tag": "section",
  "class": "video-features-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three Reasons why SUNROOOF looks and feels like real sunlight"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "Direct .mp4 URL or Shopify-hosted video URL"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail / Poster Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Features",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
