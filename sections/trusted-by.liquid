<!-- ====== PART 1: Celebrity Grid ====== -->
<div class="trusted-by-section">
  <div class="trusted-by-celebrities">
    <h2 class="trusted-by-heading">Trusted by Those Who Inspire</h2>
    <p class="trusted-by-subtext">
      Discover how renowned personalities have integrated SUNROOOF
      into their spaces...
    </p>

    <div class="trusted-by-grid">
      {% for block in section.blocks %}
        {% if block.type == 'celebrity' %}
          <div class="trusted-by-card" {{ block.shopify_attributes }}>
            <div class="trusted-by-img-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 200, height: 200, crop: 'center' }}"
                  alt="{{ block.settings.name | escape }}"
                  class="trusted-by-img"
                  width="200"
                  height="200"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'trusted-by-placeholder' }}
              {%- endif -%}
            </div>
            {% if block.settings.name != blank %}
              <span class="trusted-by-name">{{ block.settings.name }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <span class="trusted-by-title">{{ block.settings.title }}</span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- ====== PART 2: Brand Logos Strip ====== -->
  <div class="trusted-by-brands-wrapper">
    <div class="trusted-by-brands-track">
      {% for block in section.blocks %}
        {% if block.type == 'brand_logo' %}
          <div class="trusted-by-brand" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              <img
                src="{{ block.settings.logo | image_url: width: 200 }}"
                alt="{{ block.settings.name | default: 'Brand logo' | escape }}"
                class="trusted-by-brand-img"
                width="200"
                height="80"
                loading="lazy"
              >
            {%- else -%}
              <span class="trusted-by-brand-placeholder">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {% endif %}
      {% endfor %}

      {% comment %} Duplicate for seamless infinite scroll {% endcomment %}
      {% for block in section.blocks %}
        {% if block.type == 'brand_logo' %}
          <div class="trusted-by-brand" aria-hidden="true">
            {%- if block.settings.logo != blank -%}
              <img
                src="{{ block.settings.logo | image_url: width: 200 }}"
                alt="{{ block.settings.name | default: 'Brand logo' | escape }}"
                class="trusted-by-brand-img"
                width="200"
                height="80"
                loading="lazy"
              >
            {%- else -%}
              <span class="trusted-by-brand-placeholder">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
/* ── Section container ── */
.trusted-by-section {
  background-color: #000;
  padding: 100px 60px;
  color: #fff;
  overflow: hidden;
}

/* ── Part 1: Celebrities ── */
.trusted-by-heading {
  text-align: center;
  font-size: 2.5rem;
  font-weight: 500;
  letter-spacing: 0.03em;
  margin: 0 0 16px;
  color: #fff;
}

.trusted-by-subtext {
  text-align: center;
  opacity: 0.6;
  font-size: 1rem;
  max-width: 520px;
  margin: 0 auto 60px;
  line-height: 1.6;
}

.trusted-by-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 48px 32px;
  max-width: 900px;
  margin: 0 auto 100px;
}

.trusted-by-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
}

.trusted-by-img-wrap {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.trusted-by-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: grayscale(100%);
  transition: filter 0.4s ease;
}

.trusted-by-card:hover .trusted-by-img {
  filter: grayscale(0%);
}

.trusted-by-placeholder {
  width: 100%;
  height: 100%;
  display: block;
  fill: #444;
  border-radius: 50%;
  background: #222;
}

.trusted-by-name {
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.3;
}

.trusted-by-title {
  opacity: 0.5;
  font-size: 12px;
  line-height: 1.3;
}

/* ── Part 2: Brand logos strip ── */
.trusted-by-brands-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.trusted-by-brands-track {
  display: flex;
  align-items: center;
  gap: 60px;
  width: max-content;
  animation: scroll-brands 30s linear infinite;
}

.trusted-by-brands-wrapper:hover .trusted-by-brands-track {
  animation-play-state: paused;
}

.trusted-by-brand {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
}

.trusted-by-brand-img {
  height: 100%;
  width: auto;
  display: block;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.5;
  transition: filter 0.4s ease, opacity 0.4s ease;
}

.trusted-by-brand:hover .trusted-by-brand-img {
  filter: grayscale(0%);
  opacity: 1;
}

.trusted-by-brand-placeholder {
  font-size: 13px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  opacity: 0.5;
  white-space: nowrap;
  transition: opacity 0.4s ease;
}

.trusted-by-brand:hover .trusted-by-brand-placeholder {
  opacity: 1;
}

@keyframes scroll-brands {
  0%   { transform: translateX(0); }
  100% { transform: translateX(calc(-50% - 30px)); }
}

/* ── Responsive ── */
@media screen and (max-width: 768px) {
  .trusted-by-section {
    padding: 60px 20px;
  }

  .trusted-by-heading {
    font-size: 1.75rem;
  }

  .trusted-by-subtext {
    font-size: 0.9rem;
    margin-bottom: 40px;
  }

  .trusted-by-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 36px 24px;
    margin-bottom: 60px;
  }

  .trusted-by-brands-track {
    gap: 40px;
  }

  .trusted-by-brand {
    height: 30px;
  }
}
</style>

{% schema %}
{
  "name": "Trusted By",
  "settings": [],
  "blocks": [
    {
      "type": "celebrity",
      "name": "Celebrity",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title / Company",
          "default": "Title"
        }
      ]
    },
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand Name",
          "default": "Brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted By",
      "blocks": [
        { "type": "celebrity" },
        { "type": "celebrity" },
        { "type": "celebrity" },
        { "type": "celebrity" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" },
        { "type": "brand_logo" }
      ]
    }
  ]
}
{% endschema %}
