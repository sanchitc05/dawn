<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="header-logo">
      {%- if section.settings.logo_light != blank -%}
        <img
          class="logo-default"
          src="{{ section.settings.logo_light | image_url: height: 40 }}"
          alt="{{ shop.name }}"
          width="140"
          height="40"
        >
        <img
          class="logo-scrolled"
          src="{{ section.settings.logo_dark | image_url: height: 40 }}"
          alt="{{ shop.name }}"
          width="140"
          height="40"
          style="display:none;"
        >
      {%- else -%}
        <span class="logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Desktop Navigation (centered) -->
    <nav class="header-nav desktop-nav">
      <a href="{{ routes.root_url }}" class="nav-link {% if request.path == '/' %}active{% endif %}">Home</a>
      <a
        href="{{ routes.collections_url }}"
        class="nav-link {% if request.path contains 'collections' %}active{% endif %}"
        >Products</a
      >
      <a href="/pages/gallery" class="nav-link {% if request.path contains 'gallery' %}active{% endif %}">Gallery</a>
      <a href="/pages/about-us" class="nav-link {% if request.path contains 'about-us' %}active{% endif %}">About Us</a>
      <a href="/pages/contact-us" class="nav-link {% if request.path contains 'contact-us' %}active{% endif %}"
        >Contact Us</a
      >
    </nav>

    <!-- Right: Icons -->
    <div class="header-icons">
      <!-- Account -->
      <a href="{{ routes.account_url }}" class="header-icon" aria-label="Account">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="header-icon header-cart" aria-label="Cart">
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>

      <!-- Hamburger (mobile) -->
      <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu-overlay" id="mobile-menu">
  <div class="mobile-menu-inner">
    <nav class="mobile-nav">
      <a href="{{ routes.root_url }}" class="mobile-nav-link">Home</a>
      <a href="{{ routes.collections_url }}" class="mobile-nav-link">Products</a>
      <a href="/pages/gallery" class="mobile-nav-link">Gallery</a>
      <a href="/pages/about-us" class="mobile-nav-link">About Us</a>
      <a href="/pages/contact-us" class="mobile-nav-link">Contact Us</a>
    </nav>
    <div class="mobile-menu-footer">
      <a href="tel:+919811773388" class="mobile-contact-link">+91 9811773388</a>
      <a href="mailto:CONTACT@SUNROOOF.COM" class="mobile-contact-link">CONTACT@SUNROOOF.COM</a>
    </div>
  </div>
</div>

<style>
  /* ===================== HEADER ===================== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 70px;
    z-index: 200;
    display: flex;
    align-items: center;
    padding: 0 40px;
    background: transparent;
    transition: background 0.35s ease, box-shadow 0.35s ease;
  }

  .site-header.scrolled {
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .logo-text {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #fff;
    text-transform: uppercase;
  }

  .site-header.scrolled .logo-text {
    color: #000;
  }

  /* ===================== LOGO ===================== */
  .header-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    z-index: 2;
  }

  .header-logo img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* Default state: white logo visible, black logo hidden */
  .logo-default {
    display: block;
  }
  .logo-scrolled {
    display: none;
  }

  /* Scrolled state: swap logos */
  .site-header.scrolled .logo-default {
    display: none;
  }
  .site-header.scrolled .logo-scrolled {
    display: block;
  }

  .site-header.scrolled .logo-default {
    display: none !important;
  }

  .site-header.scrolled .logo-scrolled {
    display: block !important;
  }

  /* ===================== DESKTOP NAV ===================== */
  .header-nav {
    display: flex;
    gap: 36px;
  }

  .desktop-nav {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .header-nav a {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    transition: opacity 0.2s;
  }

  .header-nav a:hover {
    opacity: 0.6;
  }

  .site-header.scrolled .header-nav a {
    color: #000;
  }

  /* ===================== HEADER ACTIONS ===================== */
  .header-icons {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-icons a {
    color: #fff;
    font-size: 13px;
    letter-spacing: 0.06em;
  }

  .site-header.scrolled .header-icons a {
    color: #000;
  }

  .header-icon {
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .header-icon:hover {
    opacity: 0.7;
  }

  .site-header.scrolled .header-icon {
    color: #000000;
  }

  .cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    background: var(--color-accent, #f5e6c8);
    color: #000;
    font-size: 10px;
    font-weight: 600;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ===================== HAMBURGER ===================== */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 201;
    width: 28px;
    height: 28px;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #ffffff;
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.3s ease;
  }

  .site-header.scrolled .hamburger-line {
    background: #000000;
  }

  /* Hamburger → X animation when menu is open */
  body.menu-open .hamburger-line {
    background: #ffffff;
  }

  body.menu-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  body.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  body.menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ===================== MOBILE OVERLAY ===================== */
  .mobile-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000000;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  body.menu-open .mobile-menu-overlay {
    opacity: 1;
    visibility: visible;
  }

  body.menu-open {
    overflow: hidden;
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 100px 40px 60px;
    text-align: center;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 28px;
    flex: 1;
    justify-content: center;
  }

  .mobile-nav-link {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.3s ease;
    transform: translateY(20px);
    opacity: 0;
    animation: none;
  }

  body.menu-open .mobile-nav-link {
    animation: fadeSlideUp 0.4s ease forwards;
  }

  body.menu-open .mobile-nav-link:nth-child(1) {
    animation-delay: 0.05s;
  }
  body.menu-open .mobile-nav-link:nth-child(2) {
    animation-delay: 0.1s;
  }
  body.menu-open .mobile-nav-link:nth-child(3) {
    animation-delay: 0.15s;
  }
  body.menu-open .mobile-nav-link:nth-child(4) {
    animation-delay: 0.2s;
  }
  body.menu-open .mobile-nav-link:nth-child(5) {
    animation-delay: 0.25s;
  }

  .mobile-nav-link:hover {
    opacity: 0.6;
  }

  @keyframes fadeSlideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .mobile-menu-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    padding-bottom: 20px;
  }

  .mobile-contact-link {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--color-text-muted, #888888);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .mobile-contact-link:hover {
    color: #ffffff;
  }

  /* ===================== RESPONSIVE ===================== */
  @media screen and (max-width: 767px) {
    .header-inner {
      padding: 0 20px;
      height: 60px;
    }

    .desktop-nav {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .header-logo img {
      height: 22px;
    }
  }

  @media screen and (min-width: 768px) {
    .mobile-menu-overlay {
      display: none !important;
    }

    .hamburger {
      display: none !important;
    }
  }
</style>

<script>
  (function () {
    const header = document.getElementById('site-header');
    const hamburger = document.getElementById('hamburger-btn');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    window.addEventListener('scroll', function () {
      const h = document.querySelector('.site-header');
      if (h) h.classList.toggle('scrolled', window.scrollY > 60);
    });

    // Hamburger: toggle mobile menu
    hamburger.addEventListener('click', function () {
      const isOpen = document.body.classList.toggle('menu-open');
      hamburger.setAttribute('aria-expanded', isOpen);
    });

    // Close mobile menu on link click
    mobileLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        document.body.classList.remove('menu-open');
        hamburger.setAttribute('aria-expanded', 'false');
      });
    });

    // Close mobile menu on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && document.body.classList.contains('menu-open')) {
        document.body.classList.remove('menu-open');
        hamburger.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    { "type": "image_picker", "id": "logo_light", "label": "Logo (White version)" },
    { "type": "image_picker", "id": "logo_dark", "label": "Logo (Black version)" }
  ]
}
{% endschema %}
