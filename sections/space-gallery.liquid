<div class="space-gallery" style="background-color: #000; padding: 100px 60px;">
  <div class="space-gallery__header" style="text-align: left; margin-bottom: 50px;">
    {% if section.settings.heading != blank %}
      <h2 class="space-gallery__heading" style="color: #fff; font-size: 2.5rem; font-weight: 300; margin: 0 0 15px 0;">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="space-gallery__subtext" style="color: #fff; opacity: 0.6; max-width: 600px; margin: 0; line-height: 1.6;">
        {{ section.settings.subtext }}
      </p>
    {% endif %}
  </div>

  <div class="space-gallery__grid">
    {% for block in section.blocks %}
      <div class="space-gallery__card" {{ block.shopify_attributes }}>
        <div class="space-gallery__image-wrapper" style="position: relative; padding-bottom: 75%; background-color: #222; overflow: hidden; margin-bottom: 15px;">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" 
                 alt="{{ block.settings.image.alt | escape | default: block.settings.label }}"
                 width="800" height="600"
                 loading="lazy"
                 style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
          {% endif %}
        </div>
        {% if block.settings.label != blank %}
          <div class="space-gallery__label" style="color: #fff; text-transform: uppercase; font-size: 13px; letter-spacing: 0.1em; text-align: center;">
            {{ block.settings.label }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .space-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  @media screen and (max-width: 768px) {
    .space-gallery {
      padding: 60px 20px !important;
    }
    .space-gallery__grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      gap: 20px;
      /* Hide scrollbar */
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }
    .space-gallery__grid::-webkit-scrollbar {
      display: none; /* Chrome, Safari and Opera */
    }
    .space-gallery__card {
      flex: 0 0 80%;
    }
  }
</style>

{% schema %}
{
  "name": "Space Gallery",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Versatile for Every Space"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Whether creating a cozy, sunlit ambiance at home or a vibrant, well-lit workspace, SUNROOOF adapts to any environment with ease."
    }
  ],
  "blocks": [
    {
      "type": "space_card",
      "name": "Space Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Space Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Space Gallery",
      "blocks": [
        { "type": "space_card", "settings": { "label": "Kitchen Area" } },
        { "type": "space_card", "settings": { "label": "Dining Area" } },
        { "type": "space_card", "settings": { "label": "Office Cabin" } },
        { "type": "space_card", "settings": { "label": "Bedroom" } },
        { "type": "space_card", "settings": { "label": "Party Hall" } },
        { "type": "space_card", "settings": { "label": "Hospital Ceiling" } }
      ]
    }
  ]
}
{% endschema %}
